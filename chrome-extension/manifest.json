{
  "manifest_version": 3,
  "name": "ADHD Anchor",
  "version": "1.0",
  "description": "Your Smiski focus buddy — on every page you visit",
  "permissions": ["tabs", "storage", "webNavigation", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "css": ["smiski.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ADHD Anchor",
    "default_popup": "popup.html"
  }
}
